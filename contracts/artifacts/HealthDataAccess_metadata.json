		"devdoc": {
			"details": "健康数据存储与访问控制合约 实现数据的去中心化存储、加密和访问权限管理",
			"kind": "dev",
			"methods": {
				"batchGrantAccess(address,bytes32[],bool,bool,uint256)": {
					"details": "批量授权",
					"params": {
						"canRead": "是否可读",
						"canWrite": "是否可写",
						"dataIds": "数据ID数组",
						"duration": "授权时长",
						"requester": "请求者地址"
					}
				},
				"checkAccess(address,bytes32)": {
					"details": "检查某地址是否可读该数据（公开数据直接可读）",
					"params": {
						"dataId": "数据ID",
						"requester": "请求者地址"
					}
				},
				"checkPermission(address,bytes32)": {
					"details": "检查权限状态",
					"params": {
						"dataId": "数据ID",
						"requester": "请求者地址"
					}
				},
				"deleteData(bytes32)": {
					"details": "删除数据（仅所有者）",
					"params": {
						"dataId": "数据ID"
					}
				},
				"getContractInfo()": {
					"details": "获取合约信息"
				},
				"getDataStatus(bytes32)": {
					"details": "获取数据当前状态（0=Private, 1=Public）",
					"params": {
						"dataId": "数据ID"
					}
				},
				"getHealthData(bytes32)": {
					"details": "获取健康数据",
					"params": {
						"dataId": "数据ID"
					}
				},
				"getUserDataCount(address)": {
					"details": "获取数据数量",
					"params": {
						"user": "用户地址"
					}
				},
				"getUserDataIds(address)": {
					"details": "获取用户的所有数据ID",
					"params": {
						"user": "用户地址"
					}
				},
				"grantAccess(address,bytes32,bool,bool,uint256)": {
					"details": "授权访问权限",
					"params": {
						"canRead": "是否可读",
						"canWrite": "是否可写",
						"dataId": "数据ID",
						"duration": "授权时长（秒）",
						"requester": "请求者地址"
					}
				},
				"makeDataPrivate(bytes32)": {
					"details": "将数据改回私密（由所有者执行）",
					"params": {
						"dataId": "数据ID"
					}
				},
				"makeDataPublic(bytes32)": {
					"details": "将数据公开（由所有者执行）",
					"params": {
						"dataId": "数据ID"
					}
				},
				"revokeAccess(address,bytes32)": {
					"details": "撤销访问权限",
					"params": {
						"dataId": "数据ID",
						"requester": "请求者地址"
					}
				},
				"storeHealthData(bytes32,bytes32,string)": {
					"details": "存储健康数据",
					"params": {
						"dataHash": "数据哈希值",
						"dataType": "数据类型",
						"encryptedData": "加密后的数据"
					}
				},
				"updateHealthData(bytes32,bytes32,bytes32)": {
					"details": "更新健康数据",
					"params": {
						"dataId": "数据ID",
						"newDataHash": "新的数据哈希",
						"newEncryptedData": "新的加密数据"
					}
				}
