		"devdoc": {
			"details": "智能合约用于安全存储用户认证信息 注意：在实际生产环境中，不应该在区块链上存储明文密码 这里仅作为演示，实际应用应该使用密码哈希值",
			"kind": "dev",
			"methods": {
				"checkUserDataAccess(address,address)": {
					"details": "检查 requester 是否可访问 userAddress 的资料"
				},
				"deactivateAccount()": {
					"details": "停用用户账户"
				},
				"getActiveUsers()": {
					"details": "获取激活状态用户数量"
				},
				"getMyProfileInfo()": {
					"details": "获取当前用户完整资料信息"
				},
				"getPublicUserProfile(address)": {
					"details": "读取公开用户资料（仅在用户激活且资料为公开时可读）",
					"params": {
						"userAddress": "目标用户地址"
					}
				},
				"getTotalUsers()": {
					"details": "获取注册用户总数",
					"returns": {
						"count": "用户总数"
					}
				},
				"getUserInfo()": {
					"details": "获取用户信息（不包含敏感数据）",
					"returns": {
						"createdAt": "创建时间",
						"isActive": "是否激活",
						"usernameHash": "用户名哈希"
					}
				},
				"isUserActive(address)": {
					"details": "检查地址是否注册且激活"
				},
				"isUsernameAvailable(string)": {
					"details": "检查用户名是否可用",
					"params": {
						"username": "用户名（明文）"
					},
					"returns": {
						"available": "是否可用"
					}
				},
				"login(string,string)": {
					"details": "用户登录验证",
					"params": {
						"password": "密码（明文）",
						"username": "用户名（明文）"
					},
					"returns": {
						"success": "登录是否成功"
					}
				},
				"makeProfilePrivate()": {
					"details": "将用户资料设为私密"
				},
				"makeProfilePublic()": {
					"details": "将用户资料设为公开"
				},
				"register(string,string)": {
					"details": "注册新用户",
					"params": {
						"password": "密码（明文）",
						"username": "用户名（明文）"
					}
				},
				"registerWithProfile(string,string,bytes32,bytes32)": {
					"details": "注册用户并附带资料哈希与公钥哈希",
					"params": {
						"password": "密码（明文）",
						"profileDataHash": "用户资料哈希",
						"publicKeyHash": "用户公钥哈希",
						"username": "用户名（明文）"
					}
				},
				"updatePassword(string,string)": {
					"details": "更新密码",
					"params": {
						"newPassword": "新密码（明文）",
						"oldPassword": "旧密码（明文）"
					}
				},
				"updateUserProfile(bytes32,bytes32)": {
					"details": "更新用户资料哈希和公钥哈希",
					"params": {
						"profileDataHash": "用户资料哈希",
						"publicKeyHash": "用户公钥哈希"
					}
				}
			},
